            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"en-route\",\n  \"id_rider\": 5,\n  \"id_driver\": 2,\n  \"pickup_latitude\": 14.5995,\n  \"pickup_longitude\": 120.9842,\n  \"dropoff_latitude\": 14.5547,\n  \"dropoff_longitude\": 121.0244,\n  \"pickup_time\": \"2026-03-17T08:00:00Z\"\n}"
