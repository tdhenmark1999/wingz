            "url": {
              "raw": "{{base_url}}/api/rides/",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", ""]
            },
            "description": "Create a new ride. Accepts id_rider and id_driver as integer foreign keys."
          }
        },
        {
          "name": "Update Ride",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"pickup\",\n  \"id_rider\": 5,\n  \"id_driver\": 2,\n  \"pickup_latitude\": 14.5995,\n  \"pickup_longitude\": 120.9842,\n  \"dropoff_latitude\": 14.5547,\n  \"dropoff_longitude\": 121.0244,\n  \"pickup_time\": \"2026-03-17T08:30:00Z\"\n}"
