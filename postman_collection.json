{
  "info": {
    "name": "Wingz Ride Management API",
    "description": "Full API collection for the Wingz Ride Management assessment. Covers Login, Users, Rides (with filtering, sorting, pagination), and Ride Events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth (JWT)",
      "description": "Login to get JWT access & refresh tokens. The access token is auto-saved and used by all other requests. Use Refresh Token when the access token expires.",
      "item": [
        {
          "name": "Login (Get JWT Tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.environment.set('token', jsonData.access);",
                  "    console.log('Access token saved!');",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.environment.set('refresh_token', jsonData.refresh);",
                  "    console.log('Refresh token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            },
            "description": "Login with email and password. Returns JWT access and refresh tokens. The access token (30 min) is auto-saved to {{token}}. Each login generates NEW tokens."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.environment.set('token', jsonData.access);",
                  "    console.log('New access token saved!');",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.environment.set('refresh_token', jsonData.refresh);",
                  "    console.log('New refresh token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh", ""]
            },
            "description": "Use the refresh token to get a new access token when it expires. The new access token is auto-saved."
          }
        },
        {
          "name": "Test Unauthenticated (401)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rides/",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", ""]
            },
            "description": "No token — should return 401 Unauthorized."
          }
        }
      ]
    },
